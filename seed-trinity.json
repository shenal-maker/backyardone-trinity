    { "id": "b1-what-la-adu-zoning", "type": "WHAT", "name": "LA ADU Regulations (2024–25)", "oneliner": "Constraint — regulatory landscape",
      "blocks": [
        { "type": "assertion", "content": "SB 9 (2022): allows lot splits + duplexes on R1. AB 2221 (2023): streamlines ADU permitting, removes discretionary review. LA city ADU ordinance: allows ADUs up to 1,200 sqft on most R1 lots, junior ADUs (JADU) up to 500 sqft inside existing structure.", "col1": "", "col2": "", "outcome": "", "date": "", "notes": "", "field6": "" },
        { "type": "assertion", "content": "Key wrinkle: setbacks, lot coverage, and fire access requirements still create eligibility complexity — exactly the problem BackyardOne solves. Many homeowners and even GCs don't know what's actually allowed.", "col1": "", "col2": "", "outcome": "", "date": "", "notes": "", "field6": "" }
      ], "photo": null, "emotions": null, "datetime": null, "posX": 500, "posY": 180 },

    { "id": "b1-what-heloc-products", "type": "WHAT", "name": "ADU Financing Products", "oneliner": "Financing mechanism",
      "blocks": [
        { "type": "assertion", "content": "Primary vehicle: HELOC (~8–9% in CA as of early 2026, tracking prime). CalHFA ADU Grant: $40k forgivable grant for low-income owners — real program, underutilized due to awareness gap.", "col1": "", "col2": "", "outcome": "", "date": "", "notes": "", "field6": "" },
        { "type": "assertion", "content": "Key question: is financing friction a real blocker or a knowledge gap? CalHFA grant awareness is low even among GCs — opportunity to surface this in the product.", "col1": "", "col2": "", "outcome": "", "date": "", "notes": "", "field6": "" }
      ], "photo": null, "emotions": null, "datetime": null, "posX": 820, "posY": 340 },

    { "id": "b1-what-homeowner-pain", "type": "WHAT", "name": "Homeowner Pain Points", "oneliner": "Validated research — ADU barriers",
      "blocks": [
        { "type": "assertion", "content": "#1 barrier: cost uncertainty. #2: permitting/regulatory confusion. Typical homeowner spends 3–6 months researching before contacting first contractor.", "col1": "", "col2": "", "outcome": "", "date": "", "notes": "", "field6": "" },
