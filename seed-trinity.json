    { "id": "b1-who-homeowner-silverlake", "type": "WHO", "name": "Silver Lake R1 Homeowner", "oneliner": "Archetype — high density, walkable, strong rental demand", "interviewStatus": "unclaimed",
      "blocks": [
        { "type": "assertion", "content": "Silver Lake has among the highest ADU interest in LA — walkable, rising rents, older Craftsman and bungalow stock with detached garages ideal for conversion.", "col1": "", "col2": "", "outcome": "", "date": "", "notes": "", "field6": "" },
